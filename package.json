{
  "name": "kmjavideo",
  "version": "1.0.0",
  "description": "KMJAVideo - Electron + Vite 视频索引桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "sql.js": "^1.10.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.kmjavideo.app",
    "productName": "KMJAVideo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asar": true,
    "compression": "normal",
    "win": {
      "target": "zip",
      "icon": "public/app.ico"
    }
  }
}
